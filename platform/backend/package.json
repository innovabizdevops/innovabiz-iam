{
    "name": "innovabiz-backend",
    "version": "1.0.0",
    "description": "InnovaBiz Tenant Core Backend",
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/backend/src/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "test:ci": "jest --maxWorkers=1 --forceExit --ci",
        "genesis:master": "npx ts-node src/scripts/genesis_master_orchestrator.ts",
        "test:simulation": "npx ts-node src/scripts/launch_day_simulation.ts",
        "genesis:singularity": "npx ts-node src/scripts/genesis_singularity_event.ts",
        "genesis:launcher": "npx ts-node src/scripts/genesis_launcher.ts",
        "auth": "ts-node src/scripts/test-auth-ports.ts",
        "genesis:fractal": "ts-node src/scripts/genesis_fractal_launcher.ts",
        "genesis:simulation": "ts-node src/scripts/genesis_simulation_matrix.ts",
        "genesis:visualizer": "ts-node src/scripts/genesis_neural_visualizer.ts",
        "genesis:daemon": "ts-node src/scripts/genesis_daemon.ts",
        "genesis:galactic": "ts-node src/scripts/genesis_galactic_interlink.ts",
        "genesis:bridge": "ts-node src/scripts/genesis_quantum_bridge.ts",
        "genesis:omni": "ts-node src/scripts/genesis_omni_orchestrator.ts",
        "genesis:pipeline": "ts-node src/scripts/genesis_pentagonal_lifecycle.ts",
        "genesis:dashboard": "ts-node src/scripts/genesis_transcendent_dashboard.ts",
        "genesis:firewall": "ts-node src/scripts/genesis_sovereign_firewall.ts",
        "genesis:seal": "ts-node src/scripts/genesis_omega_convergence.ts",
        "genesis:continuum": "ts-node src/scripts/genesis_continuum_engine.ts",
        "genesis:vacuum": "ts-node src/scripts/genesis_entropy_vacuum.ts",
        "genesis:audit": "ts-node src/scripts/genesis_grand_audit.ts",
        "start:singularity": "npx ts-node src/scripts/genesis_launcher.ts"
    },
    "dependencies": {
        "@apollo/server": "^4.13.0",
        "@innovabiz/core-event-bus": "file:../solution-building-blocks/shared-code/packages/core-event-bus",
        "@innovabiz/framework-automation": "file:../solution-building-blocks/shared-code/packages/framework-automation",
        "@innovabiz/sdk-ai-agents": "file:../solution-building-blocks/shared-code/packages/sdk-ai-agents",
        "@innovabiz/sdk-blockchain-web3": "file:../solution-building-blocks/shared-code/packages/sdk-blockchain-web3",
        "@innovabiz/sdk-cosmos": "file:../solution-building-blocks/shared-code/packages/sdk-cosmos",
        "@innovabiz/sdk-evolution": "file:../solution-building-blocks/shared-code/packages/sdk-evolution",
        "@innovabiz/sdk-hyper-cube": "file:../solution-building-blocks/shared-code/packages/sdk-hyper-cube",
        "@innovabiz/sdk-knowledge": "file:../solution-building-blocks/shared-code/packages/sdk-knowledge",
        "@innovabiz/sdk-omni": "file:../solution-building-blocks/shared-code/packages/sdk-omni",
        "@innovabiz/sdk-research": "file:../solution-building-blocks/shared-code/packages/sdk-research",
        "@innovabiz/universal-factory": "file:../solution-building-blocks/shared-code/packages/universal-factory",
        "@langchain/core": "^1.1.17",
        "@langchain/openai": "^1.2.3",
        "@nestjs/apollo": "^12.2.2",
        "@nestjs/cache-manager": "^3.1.0",
        "@nestjs/common": "^10.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/event-emitter": "^3.0.1",
        "@nestjs/graphql": "^12.2.2",
        "@nestjs/platform-express": "^10.0.0",
        "@nestjs/schedule": "^6.1.0",
        "@nestjs/swagger": "^7.3.0",
        "@prisma/client": "^5.22.0",
        "@prisma/config": "^7.3.0",
        "cache-manager": "^7.2.8",
        "cache-manager-ioredis-yet": "^2.1.2",
        "cron": "^4.4.0",
        "graphql": "^16.12.0",
        "ioredis": "^5.9.3",
        "langchain": "^1.2.15",
        "prisma": "^5.22.0",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.1",
        "swagger-ui-express": "^5.0.1"
    },
    "jest": {
        "moduleFileExtensions": ["js", "json", "ts"],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "modules/**/*Service.ts",
            "modules/**/*Controller.ts",
            "!modules/**/*.spec.ts",
            "!modules/**/*.e2e-spec.ts"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node",
        "maxWorkers": 1,
        "modulePathIgnorePatterns": ["<rootDir>/../dist/"],
        "coveragePathIgnorePatterns": ["/node_modules/", "/dist/", "shared-code"]
    },
    "devDependencies": {
        "@nestjs/cli": "^10.0.0",
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.2",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.3.1",
        "@types/supertest": "^2.0.12",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "eslint": "^8.42.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "jest": "^29.5.0",
        "prettier": "^3.0.0",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3"
    }
}
